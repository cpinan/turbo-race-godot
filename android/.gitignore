# Android build template is generated by:
#   godot --headless --path . --install-android-build-template
# Do NOT commit generated template files.

# Ignore everything in build/...
build/**

# ...except our custom files
!build/.gdignore
!build/.build_version
!build/build.gradle
!build/res/
!build/res/values/
!build/res/values/game_ids.xml
!build/src/
!build/src/instrumented/
!build/src/instrumented/assets/
!build/src/instrumented/assets/.gdignore
